generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  New
  Contacted
  Interested
  Meeting_Scheduled @map("Meeting Scheduled")
  Proposal_Sent     @map("Proposal Sent")
  Negotiation
  Follow_Up         @map("Follow-Up")
  Tour_Confirmed    @map("Tour Confirmed")
  Lost
}

enum OrganizationType {
  School
  Cricket_Academy @map("Cricket Academy")
  Sports_School   @map("Sports School")
}

enum LeadSource {
  Email
  LinkedIn
  Referral
  Website
  WhatsApp
  Cold_Calling @map("Cold Calling")
}

enum Priority {
  High
  Medium
  Low
}

enum FollowUpType {
  Call
  WhatsApp
  Email
  Meeting
}

enum FollowUpStatus {
  Pending
  Completed
}

enum MeetingType {
  Zoom
  Google_Meet @map("Google Meet")
  Phone_Call  @map("Phone Call")
  In_Person   @map("In Person")
}

enum ProposalStatus {
  Sent
  Under_Review @map("Under Review")
  Accepted
  Rejected
}

enum PaymentStatus {
  Pending
  Partial
  Paid
}

enum ActivityType {
  Lead_Created        @map("Lead Created")
  Lead_Updated        @map("Lead Updated")
  Meeting_Scheduled   @map("Meeting Scheduled")
  Follow_Up_Completed @map("Follow-Up Completed")
  Proposal_Sent       @map("Proposal Sent")
  Booking_Confirmed   @map("Booking Confirmed")
  Lead_Assigned       @map("Lead Assigned")
  Note_Added          @map("Note Added")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  isActive            Boolean              @default(true)
  role                String               @default("SALES_EXECUTIVE")
  roleId              String?
  roleRecord          Role?                @relation(fields: [roleId], references: [id], onDelete: SetNull)
  department          String?
  phone               String?
  title               String?
  timezone            String?              @default("Asia/Kolkata")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  uploadedAttachments Attachment[]
  assignedLeads       Lead[]               @relation("LeadAssignee")
  createdLeads        Lead[]               @relation("LeadCreator")
  followUps           FollowUp[]           @relation("FollowUpAssignee")
  meetings            Meeting[]            @relation("MeetingOwner")
  proposals           Proposal[]           @relation("ProposalOwner")
  bookings            Booking[]            @relation("BookingOwner")
  activities          Activity[]
  notifications       Notification[]
  invitationsSent     Invitation[]         @relation("InvitationSender")
  invitationsReceived Invitation[]         @relation("InvitationReceiver")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Invitation {
  id         String   @id @default(cuid())
  email      String
  role       String
  token      String   @unique
  senderId   String
  receiverId String?
  status     String   @default("PENDING")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sender     User     @relation("InvitationSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User?    @relation("InvitationReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
}

model Lead {
  id                 String           @id @default(cuid())
  leadId             String           @unique
  schoolName         String
  organizationType   OrganizationType
  contactPerson      String
  designation        String
  email              String
  phone              String
  state              String
  city               String
  website            String?
  studentStrength    Int
  leadSource         LeadSource
  status             LeadStatus       @default(New)
  priority           Priority         @default(Medium)
  estimatedDealValue Decimal          @db.Decimal(12, 2)
  expectedCloseDate  DateTime?
  lastContactDate    DateTime?
  nextFollowUpDate   DateTime?
  notes              String?
  isArchived         Boolean          @default(false)
  createdById        String?
  assignedToId       String?
  createdBy          User?            @relation("LeadCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo         User?            @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUps          FollowUp[]
  meetings           Meeting[]
  proposals          Proposal[]
  bookings           Booking[]
  activities         Activity[]
  attachments        Attachment[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([state, city])
}

model FollowUp {
  id             String         @id @default(cuid())
  leadId         String
  assignedUserId String
  followUpDate   DateTime
  reminderTime   String
  type           FollowUpType
  status         FollowUpStatus @default(Pending)
  notes          String?
  completedAt    DateTime?
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedUser   User           @relation("FollowUpAssignee", fields: [assignedUserId], references: [id], onDelete: Cascade)
  activities     Activity[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Meeting {
  id          String      @id @default(cuid())
  leadId      String
  ownerId     String?
  meetingDate DateTime
  meetingTime String
  meetingType MeetingType
  agenda      String
  outcome     String?
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  owner       User?       @relation("MeetingOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities  Activity[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Proposal {
  id             String         @id @default(cuid())
  leadId         String
  ownerId        String?
  proposalAmount Decimal        @db.Decimal(12, 2)
  proposalDate   DateTime
  status         ProposalStatus @default(Sent)
  attachmentUrl  String?
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  owner          User?          @relation("ProposalOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  attachments    Attachment[]
  activities     Activity[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Booking {
  id                    String        @id @default(cuid())
  leadId                String?
  schoolName            String
  contactPerson         String
  assignedSalesPersonId String?
  assignedSalesPerson   User?         @relation("BookingOwner", fields: [assignedSalesPersonId], references: [id], onDelete: SetNull)
  tourType              String
  numberOfStudents      Int
  packageAmount         Decimal       @db.Decimal(12, 2)
  advancePayment        Decimal       @db.Decimal(12, 2)
  remainingPayment      Decimal       @db.Decimal(12, 2)
  paymentStatus         PaymentStatus @default(Pending)
  tourDate              DateTime
  bookingDate           DateTime
  lead                  Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activities            Activity[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  metadata    Json?
  userId      String?
  leadId      String?
  followUpId  String?
  meetingId   String?
  proposalId  String?
  bookingId   String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  followUp    FollowUp?    @relation(fields: [followUpId], references: [id], onDelete: SetNull)
  meeting     Meeting?     @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  proposal    Proposal?    @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  booking     Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())

  @@index([type, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  actionUrl String?
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, readAt])
}

model Attachment {
  id           String    @id @default(cuid())
  leadId       String?
  proposalId   String?
  name         String
  url          String
  mimeType     String?
  size         Int?
  uploadedById String?
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  proposal     Proposal? @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
}
